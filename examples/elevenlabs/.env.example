# Shared environment for the examples/elevenlabs sample.
# Copy to .env (cp .env.example .env) and fill in. The sample auto-loads it.

# --- Attention Labs SAA (streaming SDK token) -------------------------------
# Streaming-SDK auth token — NOT the hosted-bridge SAA_API_KEY. Get one at
# attentionlabs.ai/dashboard.
ATTENLABS_TOKEN=

# --- ElevenLabs Conversational AI -------------------------------------------
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=
