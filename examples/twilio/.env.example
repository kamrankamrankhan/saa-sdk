# SAA: get a key at https://attentionlabs.ai/dashboard
SAA_API_KEY=
SAA_THRESHOLD=0.7
# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# Public hostname Twilio dials (ngrok host or load-balancer), no scheme
PUBLIC_HOSTNAME=
# Reference bridges (optional)
OPENAI_API_KEY=
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=

# ── Hardening / cost-control knobs (all optional) ─────────────────────────
# Hard cap on a single call's wall-clock seconds. 0 disables (default);
# 1800 (30 min) is a sensible production ceiling against stuck streams.
MAX_CALL_DURATION_SECONDS=0
# Hang up a call idle (no inbound media) this long. 0 disables (default).
IDLE_HANGUP_SECONDS=0
# Reject new inbound calls once this many are active. 0 disables (default).
MAX_CONCURRENT_CALLS=0
# Close the Twilio WS if no frame arrives for this long (zombie reaper).
# A live call sends media every 20 ms, so 60 s of silence means it's dead.
TWILIO_WS_IDLE_TIMEOUT=60
# Max seconds to wait for the bridge's open() (it may dial an upstream LLM).
BRIDGE_OPEN_TIMEOUT=10.0
# Require a valid X-Twilio-Signature on every webhook. Off by default for
# dev; set to 1 in production AND set TWILIO_AUTH_TOKEN above.
REQUIRE_TWILIO_SIGNATURE=
