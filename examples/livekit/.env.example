# Shared environment for all examples/livekit samples.
#
# Copy to .env (cp .env.example .env) and fill in. Then, in each terminal, load
# it from the sample dir before running:
#
# The browser (web/) and the voice agent must use the SAME LiveKit project, so
# keeping LIVEKIT_* in one file here means it can't drift between them.

# --- LiveKit — every sample -------------------------------------------------
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- Attention Labs SAA — voice agents only ---------------------------------
# (the web token server doesn't summon SAA, so it ignores this)
SAA_API_KEY=

# --- OpenAI — voice agents (realtime model, or the cascaded LLM) ------------
OPENAI_API_KEY=

# --- voice_agent_cascaded only — STT + TTS providers ------------------------
# (omit if you switch the cascaded agent to LiveKit's inference gateway)
DEEPGRAM_API_KEY=
CARTESIA_API_KEY=
